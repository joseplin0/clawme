{
  "name": "clawme",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "db:comments": "node ./scripts/sync-db-comments.mjs --write",
    "db:comments:apply": "node ./scripts/sync-db-comments.mjs --write --apply",
    "db:generate": "drizzle-kit generate && node ./scripts/sync-db-comments.mjs --write",
    "db:push": "drizzle-kit push && node ./scripts/sync-db-comments.mjs --write --apply",
    "db:studio": "drizzle-kit studio",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "husky",
    "postinstall": "nuxt prepare",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run --project nuxt",
    "test:e2e": "node ./scripts/run-e2e.mjs"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.66",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/vue": "^3.0.116",
    "@iconify-json/lucide": "^1.2.97",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.6.0",
    "@nuxtjs/mdc": "^0.20.2",
    "@tailwindcss/postcss": "^4.2.1",
    "ai": "^6.0.116",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.2",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "0.5.29",
    "postgres": "^3.4.8",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "^25.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^14.2.1",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "pg": "^8.20.0",
    "reka-ui": "^2.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.0.0"
  }
}
